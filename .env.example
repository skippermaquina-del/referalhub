# Optional: enables real click tracking on /go/[slug] and the /admin/stats page.
# Create a free Redis database at https://console.upstash.com and paste the
# REST URL and token here. Without these, the site still works — clicks just
# won't be counted.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Password for /admin/stats?key=... — pick any string.
ADMIN_KEY=
